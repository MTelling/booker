{
  "name": "booker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "wrangler dev --port 8787",
    "dev:web": "npm -w web run dev",
    "build": "npm -w web run build",
    "deploy": "npm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply booker --local",
    "db:migrate:remote": "wrangler d1 migrations apply booker --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm -w web run typecheck"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.20.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14"
  }
}
